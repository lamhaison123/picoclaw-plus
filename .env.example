# PicoClaw Environment Variables
# Copy this file to .env and fill in your values
# v0.2.1: Environment variable configuration support

# ============================================
# PicoClaw Home Directory (v0.2.1)
# ============================================
# Custom home directory for PicoClaw data
# Default: ~/.picoclaw
# PICOCLAW_HOME=/custom/path/to/picoclaw

# ============================================
# LLM Provider API Keys
# ============================================

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek
# DEEPSEEK_API_KEY=sk-...

# Google Gemini
# GOOGLE_API_KEY=...

# Zhipu AI (智谱)
# ZHIPU_API_KEY=...

# Qwen (通义千问)
# QWEN_API_KEY=sk-...

# Moonshot (月之暗面)
# MOONSHOT_API_KEY=sk-...

# Groq
# GROQ_API_KEY=gsk_...

# OpenRouter
# OPENROUTER_API_KEY=sk-or-...

# ============================================
# Agent Configuration
# ============================================

# Workspace path
# PICOCLAW_AGENTS_DEFAULTS_WORKSPACE=./workspace

# Restrict to workspace
# PICOCLAW_AGENTS_DEFAULTS_RESTRICT_TO_WORKSPACE=true

# Allow read outside workspace
# PICOCLAW_AGENTS_DEFAULTS_ALLOW_READ_OUTSIDE_WORKSPACE=false

# Default model
# PICOCLAW_AGENTS_DEFAULTS_MODEL=gpt-4

# Max tokens
# PICOCLAW_AGENTS_DEFAULTS_MAX_TOKENS=32768

# Temperature
# PICOCLAW_AGENTS_DEFAULTS_TEMPERATURE=0.7

# ============================================
# Tool Configuration
# ============================================

# Enable/disable tools
# PICOCLAW_TOOLS_FILE_ENABLED=true
# PICOCLAW_TOOLS_SHELL_ENABLED=true
# PICOCLAW_TOOLS_WEB_ENABLED=true
# PICOCLAW_TOOLS_MESSAGE_ENABLED=true
# PICOCLAW_TOOLS_SPAWN_ENABLED=true
# PICOCLAW_TOOLS_TEAM_ENABLED=true
# PICOCLAW_TOOLS_SKILL_ENABLED=true
# PICOCLAW_TOOLS_HARDWARE_ENABLED=false

# Web search API keys
# BRAVE_API_KEY=...
# TAVILY_API_KEY=tvly-...
# PERPLEXITY_API_KEY=pplx-...

# New search providers (v0.2.1)
# SearXNG (privacy-focused metasearch)
# PICOCLAW_TOOLS_WEB_SEARXNG_ENABLED=false
# PICOCLAW_TOOLS_WEB_SEARXNG_BASE_URL=https://searx.example.com
# PICOCLAW_TOOLS_WEB_SEARXNG_MAX_RESULTS=5

# GLM Search (智谱AI Chinese search)
# PICOCLAW_TOOLS_WEB_GLM_ENABLED=false
# PICOCLAW_TOOLS_WEB_GLM_API_KEY=...
# PICOCLAW_TOOLS_WEB_GLM_MAX_RESULTS=5

# Exa AI (AI-powered search)
# PICOCLAW_TOOLS_WEB_EXA_ENABLED=false
# PICOCLAW_TOOLS_WEB_EXA_API_KEY=...
# PICOCLAW_TOOLS_WEB_EXA_MAX_RESULTS=5

# MCP tools
# PICOCLAW_TOOLS_MCP_ENABLED=false

# ============================================
# Session Configuration
# ============================================

# Summarization thresholds
# PICOCLAW_SESSION_SUMMARIZATION_MESSAGE_THRESHOLD=20
# PICOCLAW_SESSION_SUMMARIZATION_TOKEN_PERCENT=0.75

# ============================================
# Memory Configuration
# ============================================

# Vector memory
# PICOCLAW_MEMORY_ENABLED=false
# PICOCLAW_MEMORY_VECTOR_STORE_PROVIDER=none
# PICOCLAW_MEMORY_EMBEDDING_PROVIDER=none

# Qdrant
# PICOCLAW_MEMORY_QDRANT_URL=http://localhost:6333
# PICOCLAW_MEMORY_QDRANT_API_KEY=
# PICOCLAW_MEMORY_QDRANT_COLLECTION=picoclaw_memory

# Memory Providers
# Mem0
# PICOCLAW_MEMORY_MEM0_ENABLED=false
# PICOCLAW_MEMORY_MEM0_URL=http://localhost:8001
# PICOCLAW_MEMORY_MEM0_API_KEY=

# MindGraph (Knowledge graph for AI agents)
# Self-hosted: http://localhost:8002
# Cloud: https://api.mindgraph.cloud
# PICOCLAW_MEMORY_MINDGRAPH_ENABLED=false
# PICOCLAW_MEMORY_MINDGRAPH_URL=http://localhost:8002
# MINDGRAPH_API_KEY=

# Embedding
# PICOCLAW_MEMORY_EMBEDDING_API_KEY=
# PICOCLAW_MEMORY_EMBEDDING_MODEL=text-embedding-3-small

# ============================================
# Channel Configuration
# ============================================

# Telegram
# PICOCLAW_CHANNELS_TELEGRAM_ENABLED=false
# PICOCLAW_CHANNELS_TELEGRAM_TOKEN=

# Discord
# PICOCLAW_CHANNELS_DISCORD_ENABLED=false
# PICOCLAW_CHANNELS_DISCORD_TOKEN=

# Slack
# PICOCLAW_CHANNELS_SLACK_ENABLED=false
# PICOCLAW_CHANNELS_SLACK_BOT_TOKEN=
# PICOCLAW_CHANNELS_SLACK_APP_TOKEN=

# WhatsApp
# PICOCLAW_CHANNELS_WHATSAPP_ENABLED=false
# PICOCLAW_CHANNELS_WHATSAPP_BRIDGE_URL=ws://localhost:3001

# ============================================
# Gateway Configuration
# ============================================

# PICOCLAW_GATEWAY_HOST=127.0.0.1
# PICOCLAW_GATEWAY_PORT=18790

# ============================================
# Heartbeat Configuration
# ============================================

# PICOCLAW_HEARTBEAT_ENABLED=true
# PICOCLAW_HEARTBEAT_INTERVAL=30

# ============================================
# Skills Configuration
# ============================================

# PICOCLAW_SKILLS_MAX_CONCURRENT_SEARCHES=2
# PICOCLAW_SKILLS_REGISTRIES_CLAWHUB_ENABLED=true
# PICOCLAW_SKILLS_REGISTRIES_CLAWHUB_BASE_URL=https://clawhub.ai

# ============================================
# Advanced Configuration
# ============================================

# PicoClaw home directory (overrides ~/.picoclaw)
# PICOCLAW_HOME=/path/to/picoclaw

# Log level (debug, info, warn, error)
# PICOCLAW_LOG_LEVEL=info

# ============================================
# Notes
# ============================================
# 
# 1. Environment variables override config.json values
# 2. Existing environment variables take precedence over .env file
# 3. Use .env.local for local overrides (not committed to git)
# 4. Sensitive values (API keys) should be in .env, not config.json
# 5. Boolean values: true/false (case-insensitive)
# 6. Numeric values: integers or floats
# 7. String values: no quotes needed
#
