{
  "memory": {
    "enabled": true,
    "embedding": {
      "provider": "openai",
      "model": "text-embedding-3-small",
      "dimension": 384,
      "api_key": "${PICOCLAW_EMBEDDING_API_KEY}",
      "timeout_ms": 10000
    },
    "vector_store": {
      "provider": "qdrant",
      "qdrant": {
        "enabled": true,
        "url": "http://localhost:6333",
        "api_key": "",
        "collection": "picoclaw_memory",
        "dimension": 384,
        "timeout_ms": 800
      },
      "lancedb": {
        "enabled": false
      }
    },
    "memory_provider": {
      "provider": "none"
    },
    "cache": {
      "enabled": true,
      "max_entries": 1000,
      "ttl_seconds": 3600
    }
  }
}
