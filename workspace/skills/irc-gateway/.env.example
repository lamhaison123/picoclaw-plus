# PicoClaw IRC Gateway Configuration

# Telegram Bot Token
# The gateway will automatically load from (in priority order):
# 1. This environment variable
# 2. .env file in repo root
# 3. ~/.picoclaw/config.json (channels.telegram.token)
#
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# PicoClaw binary path (default: picoclaw)
PICOCLAW_BIN=picoclaw

# Team ID to use (default: irc-dev-team)
IRC_TEAM_ID=irc-dev-team

# Optional: Agent timeout in seconds (default: 120)
# AGENT_TIMEOUT=120

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Note: If you already have Telegram configured in ~/.picoclaw/config.json,
# you don't need to set TELEGRAM_BOT_TOKEN here. The gateway will use it automatically.
