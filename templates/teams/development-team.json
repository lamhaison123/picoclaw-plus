{
  "team_id": "dev-team-${TIMESTAMP}",
  "name": "Development Team",
  "description": "A team for software development tasks with coding, testing, and review roles",
  "pattern": "sequential",
  "roles": [
    {
      "name": "architect",
      "description": "System architect and designer",
      "capabilities": ["system_design", "architecture", "planning"],
      "tools": ["readCode", "readFile", "grepSearch"],
      "model": "gpt-4o",
      "max_tokens": 4000,
      "temperature": 0.7
    },
    {
      "name": "developer",
      "description": "Software developer",
      "capabilities": ["code_generation", "refactoring", "debugging"],
      "tools": ["readCode", "editCode", "fsWrite", "fsAppend", "executePwsh"],
      "model": "claude-sonnet-4",
      "max_tokens": 8000,
      "temperature": 0.3
    },
    {
      "name": "tester",
      "description": "Quality assurance and testing",
      "capabilities": ["testing", "validation", "bug_detection"],
      "tools": ["readCode", "readFile", "executePwsh", "getDiagnostics"],
      "model": "gpt-4o-mini",
      "max_tokens": 4000,
      "temperature": 0.5
    },
    {
      "name": "reviewer",
      "description": "Code reviewer",
      "capabilities": ["code_review", "best_practices", "security_audit"],
      "tools": ["readCode", "readFile", "grepSearch"],
      "model": "gpt-4o",
      "max_tokens": 4000,
      "temperature": 0.6
    }
  ],
  "coordinator": {
    "role": "architect",
    "agent_id": "coordinator-dev"
  },
  "settings": {
    "max_delegation_depth": 5,
    "agent_timeout_seconds": 120,
    "failure_threshold": 3,
    "consensus_timeout_seconds": 60,
    "max_spawned_agents": 10
  }
}
