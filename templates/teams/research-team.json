{
  "team_id": "research-team-${TIMESTAMP}",
  "name": "Research Team",
  "description": "A team for research and analysis tasks with web search, document analysis, and synthesis roles",
  "pattern": "parallel",
  "roles": [
    {
      "name": "researcher",
      "description": "Web researcher and information gatherer",
      "capabilities": ["web_search", "information_gathering", "fact_checking"],
      "tools": ["remote_web_search", "webFetch", "readFile", "fsWrite"],
      "model": "gpt-4o",
      "max_tokens": 8000,
      "temperature": 0.7
    },
    {
      "name": "analyst",
      "description": "Data analyst and document processor",
      "capabilities": ["document_analysis", "data_extraction", "summarization"],
      "tools": ["readFile", "readCode", "grepSearch", "fsWrite"],
      "model": "claude-sonnet-4",
      "max_tokens": 8000,
      "temperature": 0.5
    },
    {
      "name": "synthesizer",
      "description": "Information synthesizer and report writer",
      "capabilities": ["synthesis", "report_writing", "insight_generation"],
      "tools": ["readFile", "fsWrite", "fsAppend"],
      "model": "gpt-4o",
      "max_tokens": 8000,
      "temperature": 0.8
    }
  ],
  "coordinator": {
    "role": "synthesizer",
    "agent_id": "coordinator-research"
  },
  "settings": {
    "max_delegation_depth": 4,
    "agent_timeout_seconds": 180,
    "failure_threshold": 2,
    "consensus_timeout_seconds": 90,
    "max_spawned_agents": 6
  }
}
